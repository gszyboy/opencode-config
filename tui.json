{
  "$schema": "https://opencode.ai/tui.json",
  "keybinds": {
    "leader": "ctrl+\\,ctrl+x",
    "app_exit": "<leader>q",
    "terminal_suspend": "ctrl+shift+z",
    "input_undo": "ctrl+z",
    "session_interrupt": "escape,ctrl+shift+x"
  },
  "scroll_speed": 3,
  "scroll_acceleration": {
    "enabled": true
  },
  "diff_style": "auto"
}
