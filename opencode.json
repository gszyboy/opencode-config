{
  "$schema": "https://opencode.ai/config.json",
  "model": "minimax.com/MiniMax-M2.7",
  "provider": {
    "gpt-agent": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "GPT Agent Relay",
      "options": {
        "baseURL": "{env:GPT_AGENT_URL}",
        "apiKey": "{env:GPT_AGENT_KEY}"
      },
      "models": {
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4-6",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 200000,
            "output": 32768
          }
        },
        "claude-opus-4-6": {
          "name": "Claude Opus 4-6",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 200000,
            "output": 32768
          }
        },
        "gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 32768
          }
        },
        "gemini-3.1-flash": {
          "name": "Gemini 3.1 Flash",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 32768
          }
        },
        "gpt-5.4": {
          "name": "GPT 5.4",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 128000,
            "output": 32768
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT 5.4 Mini",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 128000,
            "output": 32768
          }
        },
        "MiniMax-M2.7": {
          "name": "MiniMax M2.7",
          "limit": {
            "context": 1000000,
            "output": 32768
          }
        },
        "MiniMax-M2.7-highspeed": {
          "name": "MiniMax M2.7 Highspeed",
          "limit": {
            "context": 1000000,
            "output": 32768
          }
        },
        "kimi-for-coding": {
          "name": "Kimi for Coding",
          "limit": {
            "context": 196608,
            "output": 32768
          }
        },
        "qwen3.5-plus": {
          "name": "Qwen3.5 Plus",
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "qwen3-coder-plus": {
          "name": "Qwen3 Coder Plus",
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "step-3.5-flash": {
          "name": "Step 3.5 Flash",
          "limit": {
            "context": 256000,
            "output": 32768
          }
        },
        "glm-5": {
          "name": "GLM-5",
          "limit": {
            "context": 128000,
            "output": 32768
          }
        }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@executeautomation/playwright-mcp-server"
      ],
      "enabled": false
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ]
    },
    "sequentialthinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "~"
      ]
    },
    "MiniMax": {
      "type": "local",
      "command": [
        "uvx",
        "minimax-coding-plan-mcp",
        "-y"
      ],
      "environment": {
        "MINIMAX_API_KEY": "{env:MINIMAX_API_KEY}",
        "MINIMAX_API_HOST": "https://api.minimaxi.com"
      },
      "enabled": true
    }
  },
  "tools": {
    "MiniMax": true
  },
  "instructions": [
    "~/.config/opencode/docs/general-rules.md",
    "~/.config/opencode/docs/backend-rules.md",
    "~/.config/opencode/docs/frontend-rules.md",
    "~/.config/opencode/docs/typescript-rules.md",
    "~/.config/opencode/docs/existing-project-rules.md",
    "~/.config/opencode/test/testing-guide.md"
  ],
  "plugin": [
    "oh-my-openagent@latest"
  ]
}
