{
  "$schema": "https://opencode.ai/config.json",
  "model": "minimax/MiniMax-M2.7",
  "small_model": "minimax/MiniMax-M2.5-highspeed",
  "provider": {
    "minimax": {
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "https://api.minimaxi.com/anthropic/v1",
        "apiKey": "{env:MINIMAX_API_KEY}"
      },
      "models": {
        "MiniMax-M2.7": {
          "name": "MiniMax-M2.7"
        },
        "MiniMax-M2.5": {
          "name": "MiniMax-M2.5"
        },
        "MiniMax-M2.5-highspeed": {
          "name": "MiniMax-M2.5 Highspeed"
        }
      }
    },
    "gpt-agent": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "GPT Agent Relay",
      "options": {
        "baseURL": "{env:GPT_AGENT_URL}",
        "apiKey": "{env:GPT_AGENT_KEY}"
      },
      "models": {
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4-6",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 200000,
            "output": 32768
          }
        },
        "gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 32768
          }
        },
        "gpt-5.4": {
          "name": "GPT 5.4",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 128000,
            "output": 32768
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT 5.4 Mini",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 128000,
            "output": 32768
          }
        },
        "MiniMax-M2.7-highspeed": {
          "name": "MiniMax M2.7 Highspeed",
          "limit": {
            "context": 1000000,
            "output": 32768
          }
        },
        "qwen3.5-plus": {
          "name": "Qwen3.5 Plus",
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "qwen3-coder-plus": {
          "name": "Qwen3 Coder Plus",
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "gpt-5.3-codex": {
          "name": "GPT 5.3 Codex",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 128000,
            "output": 32768
          }
        },
        "gpt-5.3-codex-spark": {
          "name": "GPT 5.3 Codex Spark",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 128000,
            "output": 32768
          }
        }
      }
    },
    "kimi-for-coding": {
      "name": "Kimi Code",
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "https://api.kimi.com/coding/v1",
        "apiKey": "{env:KIMI_API_KEY}"
      },
      "models": {
        "k2p5": {
          "name": "Kimi K2.5",
          "reasoning": true,
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "modalities": {
            "input": ["text", "image", "video"],
            "output": ["text"]
          },
          "options": {
            "interleaved": {
              "field": "reasoning_content"
            }
          }
        }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@executeautomation/playwright-mcp-server"
      ],
      "enabled": false
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ]
    },
    "sequentialthinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "~"
      ]
    },
    "MiniMax": {
      "type": "local",
      "command": [
        "uvx",
        "minimax-coding-plan-mcp",
        "-y"
      ],
      "environment": {
        "MINIMAX_API_KEY": "{env:MINIMAX_API_KEY}",
        "MINIMAX_API_HOST": "https://api.minimaxi.com"
      },
      "enabled": true
    }
  },
  "tools": {
    "MiniMax": true
  },
  "instructions": [
    "~/.config/opencode/docs/general-rules.md",
    "~/.config/opencode/docs/backend-rules.md",
    "~/.config/opencode/docs/frontend-rules.md",
    "~/.config/opencode/docs/typescript-rules.md",
    "~/.config/opencode/docs/existing-project-rules.md",
    "~/.config/opencode/test/testing-guide.md"
  ],
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "tui": {
    "scroll_speed": 3,
    "scroll_acceleration": {
      "enabled": true
    },
    "diff_style": "auto"
  }
}
