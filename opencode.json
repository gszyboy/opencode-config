{
  "$schema": "https://opencode.ai/config.json",
  "model": "minimax-cn-coding-plan/MiniMax-M2.7",
  "small_model": "minimax-cn-coding-plan/MiniMax-M2.5-highspeed",
  "provider": {
    "gpt-agent": {
      "npm": "@ai-sdk/anthropic",
      "name": "GPT Agent Relay",
      "options": {
        "baseURL": "{env:GPT_AGENT_URL}",
        "apiKey": "{env:GPT_AGENT_KEY}",
        "compatibility": "compatible"
      },
      "models": {
        "gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 32768
          }
        },
        "gpt-5.4": {
          "name": "GPT 5.4",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 32768
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT 5.4 Mini",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 128000,
            "output": 32768
          }
        },
        "MiniMax-M2.7-highspeed": {
          "name": "MiniMax M2.7 Highspeed",
          "limit": {
            "context": 1000000,
            "output": 32768
          }
        },
        "qwen3.5-plus": {
          "name": "Qwen3.5 Plus",
          "modalities": {
            "input": [
              "text",
              "image",
              "video"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "qwen3-coder-plus": {
          "name": "Qwen3 Coder Plus",
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "gpt-5.3-codex": {
          "name": "GPT 5.3 Codex",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 128000,
            "output": 32768
          },
          "variants": {
            "medium": {
              "reasoningEffort": "medium"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "high": {
              "reasoningEffort": "high"
            }
          }
        },
        "gpt-5.3-codex-spark": {
          "name": "GPT 5.3 Codex Spark",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 128000,
            "output": 32768
          }
        },
        "mimo-v2-pro": {
          "name": "Mimo V2 Pro",
          "limit": {
            "context": 128000,
            "output": 32768
          }
        },
        "mimo-v2-omni": {
          "name": "Mimo V2 Omni",
          "modalities": {
            "input": [
              "text",
              "image",
              "video",
              "audio"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 128000,
            "output": 32768
          }
        },
        "claude-opus-4-6": {
          "name": "Claude Opus 4-6",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 200000,
            "output": 32768
          }
        },
        "glm-5.1": {
          "name": "GLM-5.1",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 204800,
            "output": 131072
          }
        }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@executeautomation/playwright-mcp-server"
      ],
      "enabled": false
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": false
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "~"
      ]
    },
    "MiniMax": {
      "type": "local",
      "command": [
        "uvx",
        "minimax-coding-plan-mcp",
        "-y"
      ],
      "environment": {
        "MINIMAX_API_KEY": "{env:MINIMAX_API_KEY}",
        "MINIMAX_API_HOST": "https://api.minimaxi.com"
      },
      "enabled": true
    }
  },
  "tools": {
    "MiniMax": true
  },
  "instructions": [
    "~/.config/opencode/docs/general-rules.md",
    "~/.config/opencode/docs/backend-rules.md",
    "~/.config/opencode/docs/frontend-rules.md",
    "~/.config/opencode/docs/typescript-rules.md",
    "~/.config/opencode/docs/existing-project-rules.md"
  ],
  "plugin": [
    "oh-my-openagent@latest",
    "@tarquinen/opencode-dcp@latest"
  ]
}
